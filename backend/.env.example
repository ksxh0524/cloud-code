# Cloud Code 环境变量配置示例
# ============================================================================
# 安全警告
# 1. 此文件包含敏感信息，请勿提交到版本控制
# 2. 生产环境应使用更安全的密钥管理方式（如 Docker Secrets、Vault 等）
# 3. 文件权限建议设置为 600: chmod 600 .env
# ============================================================================

# Claude Agent SDK 配置
# -----------------------------------------------------------------------------
# 支持 Claude Code Agent SDK 或兼容 API（如智谱）
# 智谱文档: https://open.bigmodel.cn/dev/api/anthropic

# API 基础 URL（必需）
# 智谱 API: https://open.bigmodel.cn/api/anthropic
# Claude 原生: https://api.anthropic.com
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# API 认证密钥（必需）
# 智谱: 从 https://open.bigmodel.cn/ 获取 API Key
# Claude: 从 https://console.anthropic.com/ 获取
ANTHROPIC_AUTH_TOKEN=your-api-key-here

# 可选：Claude 原生 API Key（如使用原生 API）
# ANTHROPIC_API_KEY=your-anthropic-api-key

# SDK 会自动读取以下本地配置文件:
# - ~/.claude/settings.json (模型偏好、权限、环境变量等)
# - ~/.claude/mcp.json (MCP 服务器配置)
# 无需在此处重复配置

# 服务器配置
# -----------------------------------------------------------------------------
# 后端服务端口（可选，默认 18765）
PORT=18765

# 日志级别（可选，默认 info）
# 可选值: debug, info, warn, error
LOG_LEVEL=info

# 运行环境（可选，默认 development）
NODE_ENV=development

# 安全与访问控制
# -----------------------------------------------------------------------------
# API 访问密钥（可选但生产环境强烈建议设置）
# 设置后，所有 REST API 和 WebSocket 请求需要携带此密钥
# REST API: 通过 Header 传递 X-API-Key 或 Authorization: Bearer <key>
# WebSocket: 在 init 消息中传递 apiKey 字段
# 使用 timing-safe 比较，防止时序攻击
# API_KEY=your-secret-api-key-min-16-chars

# CORS 允许的来源（可选，默认 http://localhost:18766）
# 格式: 逗号分隔的 URL 列表
# 生产环境必须明确指定允许的来源
# ALLOWED_ORIGINS=http://localhost:18766,https://your-domain.com

# 安全功能说明（已内置，无需配置）
# - Helmet 安全头: 自动添加 CSP、X-Frame-Options 等安全头
# - WebSocket 限制: 最大消息 1MB，每连接每分钟最多 60 条消息
# - 路径穿越防护: conversationId 验证 UUID 格式，workDir 验证白名单
# - 错误信息脱敏: 不暴露内部错误详情

# 数据存储
# -----------------------------------------------------------------------------
# 数据存储目录（可选，默认 ~/.cloud-code）
# 包含 data.json（会话配置）和 messages/（消息历史）
# DATA_DIR=/path/to/custom/data
