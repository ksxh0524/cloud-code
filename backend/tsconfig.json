{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "outDir": "./dist"
  },
  "include": ["src/**/*", "../shared/**/*"],
  "exclude": ["node_modules", "src/cards"]
}
